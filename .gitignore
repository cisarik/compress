build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Tool caches
.mypy_cache/
.ruff_cache/
.pyre/

# Temporary files and folders
tmp/
temp/
*.tmp
*.temp

# Local editor / OS files
.DS_Store
Thumbs.db
.idea/
.vscode/

